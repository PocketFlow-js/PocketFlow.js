{
  "name": "@pocketflow/core",
  "version": "0.2.1",
  "description": "Core package for PocketFlow.js - A minimal LLM framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": [
    "llm",
    "ai",
    "machine-learning",
    "typescript"
  ],
  "author": "Mert Canatan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PocketFlow-js/PocketFlow.js.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/PocketFlow-js/PocketFlow.js#readme",
  "bugs": {
    "url": "https://github.com/PocketFlow-js/PocketFlow.js/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2"
  }
}