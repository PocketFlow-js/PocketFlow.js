{
  "name": "pocketflow",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "release": "turbo run build && changeset publish",
    "prepare": "changeset init"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "typescript-eslint": "^8.64.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": "^0.28.1",
      "ws@8": "^8.21.0",
      "yaml@2": "^2.8.3"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0"
  }
}